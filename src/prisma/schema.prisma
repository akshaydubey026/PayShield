generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DONOR
  CREATOR
  ADMIN
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  BLOCKED
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(DONOR)
  createdAt DateTime   @default(now())
  sessions  Session[]
  campaigns Campaign[]
  donations Donation[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Campaign {
  id           String     @id @default(uuid())
  title        String
  description  String
  goalAmount   Float
  raisedAmount Float      @default(0)
  imageUrl     String?
  category     String
  creatorId    String
  creator      User       @relation(fields: [creatorId], references: [id])
  donations    Donation[]
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
}

model Donation {
  id                    String         @id @default(uuid())
  amount                Float
  donorId               String
  donor                 User           @relation(fields: [donorId], references: [id])
  campaignId            String
  campaign              Campaign       @relation(fields: [campaignId], references: [id])
  stripeSessionId       String?
  stripePaymentIntentId String?
  stripeCustomerId      String?
  status                DonationStatus @default(PENDING)
  riskScore             Float          @default(0)
  isFlagged             Boolean        @default(false)
  fraudFlags            String[]
  fraudReasons          String[]
  createdAt             DateTime       @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  topic     String
  eventType String
  payload   Json
  userId    String?
  amount    Float?
  riskScore Int?
  createdAt DateTime @default(now())
}
